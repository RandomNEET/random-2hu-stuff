# Project root (set to the absolute path of this repo on the current machine)
# Local example:  PROJECT_ROOT=/home/yourname/repo/random-2hu-stuff
# Server example: PROJECT_ROOT=/root/random-2hu-stuff
PROJECT_ROOT=/path/to/random-2hu-stuff

# Server connection (used by update/upload.sh, local only)
REMOTE_SERVER=root@your.server.ip
SSH_KEY=$HOME/.ssh/key
SSH_PORT=22

# Server paths (used by deploy/ scripts, server only)
DEPLOY_TARGET=/var/www/random-2hu-stuff
PM2_APP_NAME=random-2hu-stuff-backend

# Repository references
GITHUB_REPO=username/repo
DOLTHUB_REPO=username/repo

# Frontend
FRONTEND_URL=https://example.com
